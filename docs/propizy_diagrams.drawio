        <mxCell id="s_ttl" value="M-PESA STK Push — Payment Sequence Diagram" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=17;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="190" y="16" width="680" height="36" as="geometry"/>
