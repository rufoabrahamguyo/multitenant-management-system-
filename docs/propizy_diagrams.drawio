        <!-- ── Step 4: Safaricom → Phone ── -->
        <mxCell id="s_m4" value="PIN prompt pushed to tenant phone" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=open;startArrow=none;strokeColor=#333;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="710" y="350" as="sourcePoint"/>
            <mxPoint x="985" y="350" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="s_m4_lbl" value="④ STK prompt" style="text;html=1;strokeColor=none;fillColor=#fffacd;align=left;verticalAlign=middle;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="715" y="332" width="120" height="16" as="geometry"/>
        </mxCell>

        <!-- ── Step 5: CheckoutRequestID back ── -->
        <mxCell id="s_m5" value="{ CheckoutRequestID }" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=open;startArrow=none;dashed=1;strokeColor=#9673a6;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="710" y="400" as="sourcePoint"/>
            <mxPoint x="410" y="400" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="s_m5_lbl" value="⑤ Response → store checkout_request_id" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="415" y="383" width="260" height="16" as="geometry"/>
        </mxCell>

        <!-- ── Step 6: Response to mobile ── -->
        <mxCell id="s_m6" value="{ checkout_request_id, status: &quot;pending&quot; }" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=open;startArrow=none;dashed=1;strokeColor=#82b366;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="410" y="450" as="sourcePoint"/>
            <mxPoint x="125" y="450" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="s_m6_lbl" value="⑥ Pending response to app" style="text;html=1;strokeColor=none;fillColor=#fffacd;align=left;verticalAlign=middle;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="130" y="432" width="200" height="16" as="geometry"/>
        </mxCell>

        <!-- ── Tenant action ── -->
        <mxCell id="s_act" value="Tenant enters M-PESA PIN on phone" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="850" y="472" width="220" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="s_actline" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#aaa;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="125" y="490" as="sourcePoint"/>
            <mxPoint x="850" y="490" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- ── Step 7: Callback ── -->
        <mxCell id="s_m7" value="POST /api/payments/mpesa-callback/" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=open;startArrow=none;strokeColor=#333;strokeWidth=2;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="710" y="540" as="sourcePoint"/>
            <mxPoint x="410" y="540" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="s_m7_lbl" value="⑦ Safaricom callback  { ResultCode, CheckoutRequestID, MpesaReceiptNumber }" style="text;html=1;strokeColor=none;fillColor=#fffacd;align=left;verticalAlign=middle;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="415" y="518" width="265" height="20" as="geometry"/>
        </mxCell>

        <!-- ── Step 8: API processing ── -->
        <mxCell id="s_box8" value="select_for_update(checkout_request_id)&lt;br/&gt;Verify amount matches request&lt;br/&gt;Update Payment → completed / failed&lt;br/&gt;Credit TenantWallet if overpaid&lt;br/&gt;Log WalletTransaction" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="350" y="565" width="235" height="76" as="geometry"/>
        </mxCell>
        <mxCell id="s_m8_lbl" value="⑧ Atomic processing" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="350" y="550" width="140" height="14" as="geometry"/>
        </mxCell>

        <!-- ── Step 9: PDF ── -->
        <mxCell id="s_box9" value="Generate PDF receipt (ReportLab)&lt;br/&gt;Upload to Cloudinary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="350" y="660" width="235" height="44" as="geometry"/>
        </mxCell>
        <mxCell id="s_m9_lbl" value="⑨ Receipt generation" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="350" y="645" width="150" height="14" as="geometry"/>
        </mxCell>

        <!-- ── Step 10: 200 OK ── -->
        <mxCell id="s_m10" value="HTTP 200 OK" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=open;startArrow=none;dashed=1;strokeColor=#9673a6;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="410" y="730" as="sourcePoint"/>
            <mxPoint x="710" y="730" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="s_m10_lbl" value="⑩ Acknowledge callback (required by Safaricom)" style="text;html=1;strokeColor=none;fillColor=#fffacd;align=left;verticalAlign=middle;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="415" y="712" width="280" height="16" as="geometry"/>
        </mxCell>

        <!-- ── Legend ── -->
        <mxCell id="s_leg" value="&lt;b&gt;Notes&lt;/b&gt;&lt;br/&gt;Solid arrows = synchronous calls&lt;br/&gt;Dashed arrows = response / async&lt;br/&gt;select_for_update prevents duplicate&lt;br/&gt;wallet credits on repeated callbacks" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fontSize=11;fillColor=#fffacd;strokeColor=#999;" vertex="1" parent="1">
          <mxGeometry x="60" y="560" width="240" height="90" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

</mxfile>
