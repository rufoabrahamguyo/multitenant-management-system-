        <!-- ── Step 2: API internal ── -->
        <mxCell id="s_box2" value="Validate tenant lease ownership&lt;br/&gt;Load &amp; decrypt org M-PESA config&lt;br/&gt;Create Payment (status=pending)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;" vertex="1" parent="1">
