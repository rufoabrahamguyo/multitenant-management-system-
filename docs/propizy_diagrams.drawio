        <!-- ── Step 1: Initiate ── -->
        <mxCell id="s_m1" value="POST /api/payments/initiate/   { phone, amount, lease_id }" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=open;startArrow=none;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#333;fontSize=11;" edge="1" parent="1">
