  <!-- PAGE 1 — SYSTEM ARCHITECTURE                                  -->
  <!-- ============================================================ -->
  <diagram id="p_arch" name="System Architecture">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="a_ttl" value="Propizy — System Architecture" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="290" y="20" width="500" height="40" as="geometry"/>
        </mxCell>

        <!-- Clients -->
        <mxCell id="a_web" value="&lt;b&gt;Web Dashboard&lt;/b&gt;&lt;br/&gt;React 18 + Vite&lt;br/&gt;&lt;i&gt;Property Managers &amp; Staff&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="60" y="210" width="190" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="a_mob" value="&lt;b&gt;Mobile App&lt;/b&gt;&lt;br/&gt;Expo / React Native&lt;br/&gt;&lt;i&gt;Tenants only&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="60" y="370" width="190" height="80" as="geometry"/>
        </mxCell>

        <!-- Django API -->
        <mxCell id="a_api" value="&lt;b&gt;Django REST API&lt;/b&gt;&lt;br/&gt;Modular Monolith&lt;hr/&gt;apps:  users  ·  properties  ·  payments&lt;hr/&gt;DRF 3.15  ·  SimpleJWT  ·  Gunicorn&lt;br/&gt;Docker container" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="330" y="165" width="240" height="210" as="geometry"/>
        </mxCell>

        <!-- Infrastructure -->
        <mxCell id="a_pg" value="&lt;b&gt;PostgreSQL&lt;/b&gt;&lt;br/&gt;Shared relational DB&lt;br/&gt;&lt;i&gt;Isolated by&lt;br/&gt;property_manager_id UUID&lt;/i&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="700" y="165" width="190" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="a_dar" value="&lt;b&gt;Safaricom Daraja API&lt;/b&gt;&lt;br/&gt;M-PESA STK Push&lt;br/&gt;&lt;i&gt;OAuth2  ·  HTTPS REST&lt;br/&gt;Webhook callback&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="700" y="335" width="190" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="a_cld" value="&lt;b&gt;Cloudinary&lt;/b&gt;&lt;br/&gt;File / Media Storage&lt;br/&gt;&lt;i&gt;Receipts  ·  ID photos  ·  lease PDFs&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0a30a;fontColor=#000000;strokeColor=#BD7000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="700" y="485" width="190" height="80" as="geometry"/>
        </mxCell>

        <!-- Edges -->
        <mxCell id="ae1" value="HTTPS · JWT Bearer" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;" edge="1" source="a_web" target="a_api" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ae2" value="HTTPS · JWT Bearer" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;" edge="1" source="a_mob" target="a_api" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ae3" value="Django ORM / psycopg2" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;" edge="1" source="a_api" target="a_pg" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ae4" value="STK Push + Callback" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;" edge="1" source="a_api" target="a_dar" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ae5" value="SDK file upload" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;" edge="1" source="a_api" target="a_cld" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Security note -->
        <mxCell id="a_n1" value="&lt;b&gt;Security&lt;/b&gt;&lt;br/&gt;JWT: 12h access / 7d refresh&lt;br/&gt;CORS: explicit allowlist only&lt;br/&gt;M-PESA creds: Fernet-encrypted&lt;br/&gt;IDOR tests: security_tests.py" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fontSize=11;fillColor=#fffacd;strokeColor=#999;" vertex="1" parent="1">
          <mxGeometry x="60" y="490" width="240" height="90" as="geometry"/>
        </mxCell>

        <!-- Multi-tenancy note -->
        <mxCell id="a_n2" value="&lt;b&gt;Multi-tenancy&lt;/b&gt;&lt;br/&gt;All orgs share one DB.&lt;br/&gt;Every queryset filters on&lt;br/&gt;property_manager_id UUID." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fontSize=11;fillColor=#fffacd;strokeColor=#999;" vertex="1" parent="1">
          <mxGeometry x="330" y="410" width="200" height="80" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

