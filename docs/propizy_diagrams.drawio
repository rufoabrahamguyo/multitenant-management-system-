        </mxCell>
        <mxCell id="s_api" value="&lt;b&gt;Django REST API&lt;/b&gt;&lt;br/&gt;(Backend)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="340" y="70" width="140" height="56" as="geometry"/>
        </mxCell>
        <mxCell id="s_dar" value="&lt;b&gt;Safaricom&lt;/b&gt;&lt;br/&gt;Daraja API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="640" y="70" width="140" height="56" as="geometry"/>
