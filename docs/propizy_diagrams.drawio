        <mxCell id="s_phn" value="&lt;b&gt;Tenant Phone&lt;/b&gt;&lt;br/&gt;(STK prompt)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="920" y="70" width="130" height="56" as="geometry"/>
