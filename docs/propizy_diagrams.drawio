        <!-- ── Actor Boxes ── -->
        <mxCell id="s_mob" value="&lt;b&gt;Mobile App&lt;/b&gt;&lt;br/&gt;(Tenant)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
