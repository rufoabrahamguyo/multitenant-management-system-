<mxfile host="app.diagrams.net">
  <diagram name="Payments ER" id="payments-er">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="t" value="Propizy — Payments &amp; Wallet ER (Logical)" style="text;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="400" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="lease" value="Lease&#xa;─────&#xa;PK id&#xa;FK tenant_id&#xa;FK unit_id&#xa;rent_amount&#xa;is_active" style="shape=table;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="320" y="80" width="140" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="payment" value="Payment&#xa;─────&#xa;PK id&#xa;FK lease_id&#xa;FK tenant_id&#xa;amount, status&#xa;checkout_request_id&#xa;mpesa_receipt_no&#xa;month_paid" style="shape=table;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="80" y="280" width="160" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="wallet" value="TenantWallet&#xa;─────&#xa;PK id&#xa;FK tenant_id (UQ)&#xa;balance" style="shape=table;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="320" y="280" width="140" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="wtxn" value="WalletTransaction&#xa;─────&#xa;PK id&#xa;FK wallet_id&#xa;amount, balance_after&#xa;FK payment_id (opt)" style="shape=table;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="520" y="280" width="150" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="invoice" value="Invoice&#xa;─────&#xa;PK id&#xa;FK lease_id&#xa;month, amount&#xa;status" style="shape=table;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="130" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="cash" value="CashCollection&#xa;─────&#xa;PK id&#xa;FK lease_id&#xa;amount, status&#xa;FK payment_id (opt)" style="shape=table;startSize=30;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="520" y="80" width="150" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="stmt" value="MpesaStatementLine&#xa;─────&#xa;PK id&#xa;FK import_id&#xa;receipt_number&#xa;FK matched_payment_id" style="shape=table;startSize=30;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="320" y="450" width="170" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="e1" style="endArrow=ERmany;startArrow=ERone;" edge="1" parent="1" source="lease" target="payment">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" style="endArrow=ERmany;startArrow=ERone;" edge="1" parent="1" source="lease" target="invoice">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" style="endArrow=ERmany;startArrow=ERone;" edge="1" parent="1" source="lease" target="cash">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" style="endArrow=ERmany;startArrow=ERone;" edge="1" parent="1" source="wallet" target="wtxn">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5" style="endArrow=ERzeroToOne;startArrow=ERmany;dashed=1;" edge="1" parent="1" source="payment" target="wtxn">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e6" style="endArrow=ERzeroToOne;startArrow=ERone;dashed=1;" edge="1" parent="1" source="stmt" target="payment">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
