SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# PostgreSQL — Docker Compose maps the db service to host port 5435 (see docker-compose.yml)
DB_NAME=propizy
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5435

# M-PESA platform callback (shared URL for all organizations' STK callbacks)
MPESA_CALLBACK_URL=https://your-ngrok-url.ngrok.io/api/payments/mpesa-callback/
MPESA_ENV=sandbox

# REQUIRED in production — authenticates Safaricom callbacks (X-MPESA-Callback-Secret header).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
MPESA_CALLBACK_SECRET=

# Recommended: set a dedicated key so rotating SECRET_KEY does not break stored Daraja credentials.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
MPESA_ENCRYPTION_KEY=

# Per-organization Daraja credentials are stored encrypted in the database.
# Owners submit integration requests via Governance → M-PESA; the Propizy team completes setup in Django admin.
# MPESA_OPS_EMAIL=integrations@yourdomain.com
# Legacy platform keys below are optional and no longer used for tenant STK push:
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
# MPESA_SHORTCODE=174379
# MPESA_PASSKEY=

# Celery async task queue (email, SMS, PDF generation).
# When unset, tasks run synchronously (dev mode — no Redis needed).
# Docker Compose sets this automatically for the celery service.
# CELERY_BROKER_URL=redis://localhost:6379/0

# Web dashboard URL (used in invite emails and staff invite links)
FRONTEND_URL=http://localhost:5173
MOBILE_APP_SCHEME=propizy

# Email (optional in dev — prints to console; required in production)
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD=re_xxxxxxxx
# DEFAULT_FROM_EMAIL=Propizy <invites@yourdomain.com>

# Extra CORS origins (comma-separated) for production frontends
# CORS_ALLOWED_ORIGINS=https://app.propizy.app

# Cloudinary (optional — local media/ folder when not set)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Africa's Talking SMS (optional — simulates when not configured)
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=
